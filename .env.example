# =============================================================
# AUROS MKT — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores
# =============================================================

# Supabase — Projeto: Auros (South America - São Paulo)
# Encontre em: https://supabase.com/dashboard/project/SEU_PROJECT_REF/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua_anon_key_aqui

# ATENÇÃO: SERVICE_ROLE_KEY — acesso total ao banco, NUNCA no client-side!
# Encontre em: https://supabase.com/dashboard/project/SEU_PROJECT_REF/settings/api
SUPABASE_SERVICE_ROLE_KEY=sua_service_role_key_aqui

# xAI Grok — Motor de IA principal do AUROS
# Obtenha em: https://console.x.ai → API Keys
XAI_API_KEY=xai-sua_chave_aqui
